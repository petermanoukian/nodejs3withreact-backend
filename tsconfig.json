{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {


    // Environment Settings
    // See also https://aka.ms/tsconfig/module

    "ignoreDeprecations": "6.0", 

    "rootDir": "./src",
    "outDir": "./dist",
    
    "typeRoots": ["./src/types", "./node_modules/@types"],

    "paths": {
      "@config/*": ["config/*"],
      "@Model/*": ["app/Model/*"],
      "@Repository/*": ["app/Repository/*"],
      "@RepositoryInterface/*": ["app/Repository/Interface/*"],
      "@RepositoryQueries/*": ["app/Repository/Queries/*"],
      "@Service/*": ["app/Service/*"],
      "@ServiceInterface/*": ["app/Service/Interface/*"],
      "@ServiceAction/*": ["app/Service/Action/*"],
      "@Http/*": ["app/http/*"],
      "@HttpControllers/*": ["app/http/Controllers/*"],
      "@HttpMiddleware/*": ["app/http/Middleware/*"],
      "@HttpRequest/*": ["/app/http/Request/*"]
    },



    "module": "nodenext", 
    "target": "esnext",
    "types": ["node", "express", "express-session", "multer"],

    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  }
}
