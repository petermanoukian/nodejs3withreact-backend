{
  "name": "nodejs3",
  "version": "1.0.0",
  "description": "",
  "main": "src/app.ts",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "ts-node -r tsconfig-paths/register src/app.ts",
    "build": "tsc && tsc-alias && copyfiles -u 1 \"src/config/*.pem\" dist/config",
    "migrate": "knex --knexfile src/config/knexfile.ts migrate:latest",
    "rollback": "knex --knexfile src/config/knexfile.ts migrate:rollback",
    "seed": "ts-node -r tsconfig-paths/register src/database/Seeder/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/express-validator": "^2.20.33",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.9",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "sharp": "^0.34.5"
  }
}
